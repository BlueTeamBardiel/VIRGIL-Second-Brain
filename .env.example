# VIRGIL — Required Environment Variables
# Copy this file to .env and fill in your values.
# Add the following to your crontab so scripts can self-source them:
#   ANTHROPIC_API_KEY="your-key-here"
#   SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# ── Required (or use Option B below for local inference) ─────────────────────

# Anthropic API key — used by all Claude Haiku ingest and automation scripts
# Get yours at: https://console.anthropic.com/
# Optional if running local inference via Ollama — see GETTING-STARTED.md Option B
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Root path of your VIRGIL vault
# Default if unset: $HOME/VIRGIL
# VIRGIL_DIR=/home/your-username/Documents/VIRGIL

# Knowledge track — affects which RSS feeds are prioritized
# Options: security | networking | both (default: both)
VIRGIL_TRACK=both

# ── Optional ──────────────────────────────────────────────────────────────────

# Slack incoming webhook — enables notifications from hooks and ingest scripts
# If unset, Slack notifications are silently skipped (scripts still run)
# Create a webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Local inference via Ollama (Option B — no API key required) ───────────────

# Set to 'ollama' to use a local model instead of the Anthropic API
# VIRGIL_BACKEND=ollama

# Ollama base URL (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Model to use for Ollama inference (e.g. qwen2.5:14b, llama3.1:8b)
# OLLAMA_MODEL=qwen2.5:14b

